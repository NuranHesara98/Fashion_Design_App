# Server Configuration
PORT=5003
NODE_ENV=development

# MongoDB Configuration
# The application will check for either MONGO_URI or MONGODB_URI
MONGO_URI=mongodb+srv://username:password@your-cluster-url/database
# MONGODB_URI=mongodb+srv://username:password@your-cluster-url/database

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# Client Configuration (for CORS)
CLIENT_URL=http://localhost:3000

# OpenAI Configuration
# The application will check for either OPENAI_API_KEY or OPENAI_KEY
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_KEY=your_openai_api_key_here

# AWS S3 Configuration
# Required for image storage
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=your_aws_region
# The application will check for either AWS_S3_BUCKET_NAME or S3_BUCKET_NAME
AWS_S3_BUCKET_NAME=your_aws_s3_bucket_name
# S3_BUCKET_NAME=your_aws_s3_bucket_name
